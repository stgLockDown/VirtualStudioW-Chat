# ═══════════════════════════════════════════════════════════════
# Virtual Studio — Environment Variables
# ═══════════════════════════════════════════════════════════════

# PostgreSQL Database (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/virtualstudio
DB_SSL=false

# Authentication
JWT_SECRET=change-this-to-a-random-secret-string
JWT_EXPIRY=7d

# Server
PORT=3000

# Recordings storage directory
RECORDINGS_DIR=./recordings

# AI Summary Generation (optional)
OPENAI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini