# ═══════════════════════════════════════════════════════════════════════
# Virtual Studio — Environment Variables
# Copy this file to .env for local development
# On Railway, set these in the Railway dashboard under Variables
# ═══════════════════════════════════════════════════════════════════════

# ── DATABASE (Required for production) ────────────────────────────────
# Railway auto-provides DATABASE_URL when you add a PostgreSQL plugin.
# Leave empty for local SQLite mode (desktop/dev).
DATABASE_URL=postgresql://user:password@localhost:5432/virtualstudio

# Set to true to force SSL on non-Railway PostgreSQL connections
DB_SSL=false

# ── AUTHENTICATION (Required) ──────────────────────────────────────────
# CHANGE THIS to a long random secret in production!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-random-64-char-secret-string

# Token expiry duration (7d = 7 days)
JWT_EXPIRY=7d

# ── SERVER ─────────────────────────────────────────────────────────────
# Railway automatically sets PORT — do not hardcode this in production
PORT=3000

# Set to 'production' on Railway
NODE_ENV=production

# ── CORS (Optional) ────────────────────────────────────────────────────
# Set this to your Electron app URL or custom domain to restrict CORS.
# Leave empty to allow all origins (fine for Railway + Electron setup).
FRONTEND_URL=

# ── RECORDINGS (Optional) ─────────────────────────────────────────────
# Where to store uploaded recordings.
# On Railway, use a mounted volume or leave empty (uses ./recordings).
# NOTE: Railway's filesystem is ephemeral — use object storage for
# permanent recording storage in production.
RECORDINGS_DIR=./recordings

# ── AI SUMMARIES (Optional) ────────────────────────────────────────────
# Provide an OpenAI-compatible API key to enable auto meeting summaries.
# Leave blank to disable AI summary generation.
OPENAI_API_KEY=

# Override the OpenAI base URL (e.g. for Azure OpenAI or local Ollama)
AI_BASE_URL=https://api.openai.com/v1

# Model to use for summary generation
AI_MODEL=gpt-4o-mini